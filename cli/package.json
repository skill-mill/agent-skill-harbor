{
	"name": "agent-skill-harbor",
	"version": "0.11.0",
	"type": "module",
	"description": "Skill governance for companies. Skill discovery for teams.",
	"keywords": [
		"agent",
		"skill",
		"agent-skills",
		"skill-management",
		"governance",
		"claude",
		"skill-md",
		"github",
		"cli"
	],
	"license": "MIT",
	"packageManager": "pnpm@10.32.1",
	"engines": {
		"node": ">=24"
	},
	"bin": {
		"harbor": "./dist/bin/cli.js",
		"agent-skill-harbor": "./dist/bin/cli.js"
	},
	"files": [
		"dist/",
		"templates/"
	],
	"scripts": {
		"format": "prettier --write \"bin/**/*.{js,ts,mjs,cjs,mts,cts}\" \"src/**/*.{js,ts,mjs,cjs,mts,cts}\" \"*.{js,ts,mjs,cjs,mts,cts,json,md}\"",
		"format:check": "prettier --check \"bin/**/*.{js,ts,mjs,cjs,mts,cts}\" \"src/**/*.{js,ts,mjs,cjs,mts,cts}\" \"*.{js,ts,mjs,cjs,mts,cts,json,md}\"",
		"lint": "eslint --fix bin src",
		"lint:check": "eslint bin src",
		"test": "node --import tsx --test src/runtime/audit/*.test.ts",
		"check": "tsc --noEmit -p tsconfig.json",
		"verify": "pnpm format:check && pnpm lint:check && pnpm check",
		"build": "tsup"
	},
	"dependencies": {
		"@octokit/rest": "^21.1.1",
		"agent-skill-harbor-web": ">=0.8.7 <1",
		"js-yaml": "^4.1.0"
	},
	"devDependencies": {
		"@types/js-yaml": "^4.0.9",
		"@types/node": "^22.15.0",
		"eslint": "^9.18.0",
		"tsup": "8.5.1",
		"tsx": "^4.19.0",
		"typescript": "^5.7.0",
		"typescript-eslint": "^8.20.0"
	}
}
