{
	"name": "agent-skill-harbor",
	"version": "0.14.0",
	"type": "module",
	"description": "Skill governance for companies. Skill discovery for teams.",
	"keywords": [
		"agent",
		"skill",
		"agent-skills",
		"skill-management",
		"governance",
		"claude",
		"skill-md",
		"github",
		"cli"
	],
	"license": "MIT",
	"packageManager": "pnpm@10.32.1",
	"engines": {
		"node": ">=24"
	},
	"bin": {
		"harbor": "./dist/bin/cli.js",
		"agent-skill-harbor": "./dist/bin/cli.js"
	},
	"files": [
		"dist/",
		"templates/"
	],
	"scripts": {
		"format": "prettier --write \"bin/**/*.{js,ts,mjs,cjs,mts,cts}\" \"src/cli/gen.ts\" \"src/cli/paths.ts\" \"src/cli/commands/{gen,init}.ts\" \"*.{js,ts,mjs,cjs,mts,cts,json,md}\"",
		"format:check": "prettier --check \"bin/**/*.{js,ts,mjs,cjs,mts,cts}\" \"src/cli/gen.ts\" \"src/cli/paths.ts\" \"src/cli/commands/{gen,init}.ts\" \"*.{js,ts,mjs,cjs,mts,cts,json,md}\"",
		"lint": "eslint --fix bin/cli.ts src/cli/paths.ts src/cli/gen.ts src/cli/commands/init.ts src/cli/commands/gen.ts",
		"lint:check": "eslint bin/cli.ts src/cli/paths.ts src/cli/gen.ts src/cli/commands/init.ts src/cli/commands/gen.ts",
		"test": "node --import tsx --test \"src/cli/**/*.test.ts\"",
		"check": "tsc --noEmit -p tsconfig.json",
		"verify": "pnpm format:check && pnpm lint:check && pnpm check",
		"build": "tsup"
	},
	"peerDependencies": {
		"agent-skill-harbor-collector": ">=0.14.0 <1",
		"agent-skill-harbor-post-collect": ">=0.14.0 <1",
		"agent-skill-harbor-web": ">=0.14.0 <1"
	},
	"peerDependenciesMeta": {
		"agent-skill-harbor-collector": {
			"optional": true
		},
		"agent-skill-harbor-post-collect": {
			"optional": true
		},
		"agent-skill-harbor-web": {
			"optional": true
		}
	},
	"devDependencies": {
		"@types/node": "^22.15.0",
		"eslint": "^9.18.0",
		"tsup": "8.5.1",
		"tsx": "^4.19.0",
		"typescript": "^5.7.0",
		"typescript-eslint": "^8.20.0",
		"agent-skill-harbor-collector": "workspace:*",
		"agent-skill-harbor-post-collect": "workspace:*",
		"agent-skill-harbor-web": "workspace:*"
	}
}
