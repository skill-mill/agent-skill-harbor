{
	"name": "agent-skill-harbor-collector",
	"version": "0.15.3",
	"type": "module",
	"description": "Collector and post-collect runtime package for Agent Skill Harbor.",
	"license": "MIT",
	"packageManager": "pnpm@10.32.1",
	"engines": {
		"node": ">=24"
	},
	"files": [
		"dist/"
	],
	"scripts": {
		"format:raw": "prettier \"src/**/*.{js,ts}\" \"*.{json,md}\"",
		"format": "pnpm run -s format:raw --write",
		"format:check": "pnpm run -s format:raw --check",
		"lint": "eslint src",
		"lint:fix": "eslint --fix src",
		"typecheck": "tsc --noEmit -p tsconfig.json",
		"test": "node --import tsx --test \"src/**/*.test.ts\"",
		"build": "tsup",
		"verify": "pnpm run format:check && pnpm run lint && pnpm run typecheck && pnpm run test",
		"fix": "pnpm run format && pnpm run lint:fix && pnpm run typecheck && pnpm run test"
	},
	"dependencies": {
		"@octokit/rest": "^21.1.1",
		"js-yaml": "^4.1.0",
		"tsx": "^4.19.0"
	},
	"devDependencies": {
		"@types/js-yaml": "^4.0.9",
		"@types/node": "^22.15.0",
		"eslint": "^9.18.0",
		"tsup": "8.5.1",
		"typescript": "^5.7.0",
		"typescript-eslint": "^8.20.0"
	}
}
